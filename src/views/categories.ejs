<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <p>
            <a href="/new-category">Create New Category</a>
        </p>

        <h2>Service Project Categories</h2>
        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                </li>
                <% }) %>
        </ul>
    </main>

    <%- include('partials/footer') %>