<%- include('partials/header') %>

    <main>

        <h1>
            <%= title %>
        </h1>

        <form action="/edit-project/<%= project.project_id %>" method="POST">

            <div class="form-group">
                <label for="title">Title</label>
                <input type="text" id="title" name="title" value="<%= project.title %>" required minlength="3"
                    maxlength="200">
            </div>

            <div class="form-group">
                <label for="description">Description</label>

                <textarea id="description" name="description" required
                    maxlength="1000"><%= project.description %></textarea>
            </div>

            <div class="form-group">
                <label for="location">Location</label>

                <input type="text" id="location" name="location" value="<%= project.location %>" required
                    maxlength="200">
            </div>

            <div class="form-group">
                <label for="date">Date</label>

                <input type="date" id="date" name="date"
                    value="<%= new Date(project.project_date).toISOString().split('T')[0] %>" required>

            </div>

            <div class="form-group">
                <label for="organizationId">Organization</label>

                <select id="organizationId" name="organizationId" required>

                    <% organizations.forEach((organization)=> { %>

                        <option value="<%= organization.organization_id %>"
                            <%=organization.organization_id===project.organization_id ? 'selected' : '' %>
                            >
                            <%= organization.name %>
                        </option>

                        <% }) %>

                </select>

            </div>

            <button type="submit">
                Update Project
            </button>

        </form>

    </main>

    <%- include('partials/footer') %>