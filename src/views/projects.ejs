<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>

    <ul>
        <% projects.forEach(project => { %>
            <li>
                <strong>
                    <%= new Date(project.project_date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    }) %>
                </strong>:
                <%= project.title %>
                (<em><%= project.organization_name %></em>)
            </li>
        <% }) %>
    </ul>
</main>

<%- include('partials/footer') %>